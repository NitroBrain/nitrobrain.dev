---
import ThemeToggle from '../features/theme/ThemeToggle.tsx'
---
<header class="px-6 sm:px-10 max-w-3xl mx-auto py-6 flex items-center justify-between border-b border-gray-100 dark:border-white/10">
  <a href="#" class="font-mono text-sm font-semibold text-gray-900 dark:text-gray-100">
    NitroBrain
  </a>

  <div class="flex items-center gap-4">
    <ThemeToggle client:load />

    <a
      href="https://github.com/NitroBrain"
      target="_blank"
      rel="noopener noreferrer"
      class="font-mono text-sm text-gray-500 dark:text-gray-400 hover:text-[#28a745] transition-colors"
    >
      GitHub
    </a>
  </div>
</header>
