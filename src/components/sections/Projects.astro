---
import repos from '../../data/repos.ts'
---

<section id="projects" class="px-6 sm:px-10 max-w-3xl mx-auto py-20 border-t border-gray-100">
  <div class="flex items-baseline justify-between mb-12 gap-4">
    <h2 class="font-serif text-3xl text-gray-900">Projects</h2>
    <span class="font-mono text-xs text-gray-400 text-right">{repos.length} projects</span>
  </div>

  {repos.length === 0 ? (
    <p class="text-gray-500 text-sm">No projects to show yet.</p>
  ) : (
    <ol class="divide-y divide-gray-100">
      {repos.map((repo, i) => (
        <li>
          <a
            href={repo.repo_url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-start gap-6 py-6"
          >
            <span class="font-mono text-sm text-gray-200 group-hover:text-[#28a745] w-8 shrink-0 pt-1">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="flex-1 min-w-0">
              <h3 class="font-mono font-semibold text-gray-900 group-hover:text-[#28a745]">
                {repo.name}
              </h3>
              <p class="text-gray-500 text-sm mt-1">
                {repo.description || 'No description provided.'}
              </p>
            </div>
          </a>
        </li>
      ))}
    </ol>
  )}
</section>
